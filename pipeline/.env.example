# 复制为 .env 并填值；.env 已被 .gitignore 忽略，切勿提交。
VAULT_PATH=C:/Users/you/Documents/vault   # Obsidian vault 本地路径（Windows 用正斜杠即可）
DEEPSEEK_API_KEY=sk-xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=                              # 填最新 Claude Opus 模型ID
DEEPSEEK_MODEL=deepseek-chat              # 批量活；推理可用 deepseek-reasoner
# 以下可选，有默认值：
# API_TIMEOUT=60        # 分类请求超时（秒）
# REVIEW_TIMEOUT=120    # 周复盘请求超时（秒）
# API_MAX_RETRIES=2     # 请求失败重试次数（SDK 指数退避）
